{
  "name": "@chfischerx/puttry",
  "version": "0.9.3",
  "description": "PuTTrY - Web-based terminal with real PTY, WebSocket I/O, and xterm.js frontend",
  "type": "module",
  "author": "Christian Fischer <christian@fischerx.com>",
  "license": "MIT",
  "main": "./dist-server/server.js",
  "bin": {
    "puttry": "./dist-server/cli.js"
  },
  "files": [
    "dist-server/",
    "dist/",
    ".env.example",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:server": "esbuild src/server/server.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist-server/server.js --external:fsevents --external:express --external:winston --external:@colors/colors --external:logform --external:ws --external:node-pty --external:qrcode --external:otplib --external:@simplewebauthn/server --external:archiver",
    "build:cli": "esbuild src/server/cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist-server/cli.js --external:fsevents --external:express --external:winston --external:@colors/colors --external:logform --external:ws --external:node-pty --external:qrcode --external:otplib --external:@simplewebauthn/server --external:archiver",
    "build:all": "npm run build && npm run build:server && npm run build:cli",
    "prepublishOnly": "npm run build:all",
    "start": "node --env-file=.env dist-server/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@simplewebauthn/server": "^13.3.0",
    "archiver": "^7.0.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "node-pty": "^1.0.0",
    "otplib": "^13.4.0",
    "qrcode": "^1.5.4",
    "winston": "^3.14.2",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@simplewebauthn/browser": "^13.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.11",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.1",
    "@vitest/ui": "^4.1.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "lucide-react": "^0.575.0",
    "memfs": "^4.57.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "supertest": "^7.2.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  }
}
